<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.parkingmanage.mapper.AcmsEventRecordMapper">

    <!-- 根据事件ID查询记录 -->
    <select id="selectByEventId" resultType="com.parkingmanage.entity.AcmsEventRecord">
        SELECT * FROM acms_event_record
        WHERE event_id = #{eventId}
        AND deleted = 0
        LIMIT 1
    </select>

</mapper>

